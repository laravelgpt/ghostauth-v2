{
    "name": "ghostauth/ghostauth",
    "description": "A modern, Auth0-inspired, PHP 8.3+ authentication library. Framework-agnostic, PSR-compliant, and enterprise-ready.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "authentication", "auth", "jwt", "otp", "oauth2", "oidc", "sso", "mfa",
        "passwordless", "psr-7", "psr-11", "psr-15", "php8", "security"
    ],
    "authors": [
        {
            "name": "GhostAuth Contributors",
            "email": "hello@ghostauth.dev",
            "homepage": "https://ghostauth.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^6.10",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-strict-rules": "^1.6",
        "nyholm/psr7": "^1.8",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "GhostAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GhostAuth\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
